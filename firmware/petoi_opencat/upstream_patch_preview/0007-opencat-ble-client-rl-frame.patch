+void bleWriteRlResponse(const uint8_t* data, size_t len, void* userData) {
+  (void)userData;
+  if (data != nullptr && len > 0 && len <= sizeof(bleRlPendingResponse)) {
+    Serial.print("BLE RL response bytes: ");
+    Serial.println(len);
+    memcpy(bleRlPendingResponse, data, len);
+    bleRlPendingResponseLen = len;
+  } else {
+    Serial.println("BLE RL response dropped");
+  }
+}
+
+void processBleRlPendingResponse() {
+  if (pRemoteCharacteristicTx == nullptr || bleRlPendingResponseLen == 0) {
+    return;
+  }
+
+  size_t offset = 0;
+  while (offset < bleRlPendingResponseLen) {
+    const size_t chunkLen = (bleRlPendingResponseLen - offset) > 20 ? 20 : (bleRlPendingResponseLen - offset);
+    Serial.print("BLE RL response chunk: ");
+    Serial.println(chunkLen);
+    pRemoteCharacteristicTx->writeValue(bleRlPendingResponse + offset, chunkLen, false);
+    offset += chunkLen;
+    delay(10);
+  }
+  bleRlPendingResponseLen = 0;
+}
+
+bool handleBleRlFrameBytes(const uint8_t* data, size_t length) {
+  if (data == nullptr || length == 0) {
+    return false;
+  }
+
+  size_t offset = 0;
+  if (!bleRlFrameInProgress) {
+    if (data[0] != T_RL_FRAME) {
+      return false;
+    }
+    rlFrameReader.Reset();
+    bleRlFrameInProgress = true;
+    Serial.println("BLE RL token");
+    offset = 1;
+  }
+
+  if (offset >= length) {
+    return true;
+  }
+
+  rl_serial_v0::FrameView frame;
+  const auto feedStatus = rlFrameReader.Feed(data + offset, length - offset, &frame);
+  if (feedStatus == rl_frame_reader_v0::FeedStatus::kNeedMore) {
+    Serial.print("BLE RL need more, bytes: ");
+    Serial.println(length - offset);
+    return true;
+  }
+
+  if (feedStatus == rl_frame_reader_v0::FeedStatus::kFrameReady) {
+    Serial.println("BLE RL frame ready");
+    HandleBufferedRlFrame(bleWriteRlResponse, nullptr);
+  } else {
+    Serial.print("BLE RL frame rejected: ");
+    Serial.println((int)feedStatus);
+  }
+
+  rlFrameReader.Reset();
+  bleRlFrameInProgress = false;
+  return true;
+}
