+bool HandleBufferedRlFrame(RlResponseWriter writer, void* userData) {
+  rl_serial_v0::FrameView frame;
+  if (rl_serial_v0::DecodeFrame(rlFrameReader.frame_data(), rlFrameReader.frame_size(), &frame) !=
+      rl_serial_v0::ParseError::kOk) {
+    rlFrameReader.Reset();
+    return false;
+  }
+
+  if (frame.message_type == rl_serial_v0::kMsgSetTargetsReq) {
+    float targets[rl_serial_v0::kTargetCount] = {};
+    bool targetsAccepted =
+        rl_serial_v0::DecodeTargetsPayload(frame, targets) == rl_serial_v0::ParseError::kOk;
+    byte rejectedTargetIndex = 0xFF;
+    byte rejectedJointIndex = 0xFF;
+    byte rejectedReason = 0;
+
+    float targetDeg[rl_serial_v0::kTargetCount] = {};
+    for (byte i = 0; i < rl_serial_v0::kTargetCount && targetsAccepted; i++) {
+      const byte jointIndex = DOF - WALKING_DOF + i;
+      targetDeg[i] = targets[i] * degPerRad;
+      if (targetDeg[i] != targetDeg[i]) {
+        targetsAccepted = false;
+        rejectedTargetIndex = i;
+        rejectedJointIndex = jointIndex;
+        rejectedReason = 1;
+      } else if (targetDeg[i] < angleLimit[jointIndex][0]) {
+        targetsAccepted = false;
+        rejectedTargetIndex = i;
+        rejectedJointIndex = jointIndex;
+        rejectedReason = 2;
+      } else if (targetDeg[i] > angleLimit[jointIndex][1]) {
+        targetsAccepted = false;
+        rejectedTargetIndex = i;
+        rejectedJointIndex = jointIndex;
+        rejectedReason = 3;
+      }
+    }
+
+    if (targetsAccepted) {
+      for (byte i = 0; i < rl_serial_v0::kTargetCount; i++) {
+        calibratedPWM(DOF - WALKING_DOF + i, targetDeg[i]);
+      }
+    }
+
+    uint16_t status =
+        targetsAccepted ? rl_serial_v0::kStatusCommandAccepted : rl_serial_v0::kStatusInternalFault;
+    if (!targetsAccepted && rejectedJointIndex < DOF) {
+      status |= (uint16_t)(rejectedJointIndex & 0x0F) << 8;
+      status |= (uint16_t)(rejectedReason & 0x0F) << 12;
+    }
+    rlResponseLen =
+        rl_serial_v0::EncodeSetTargetsResponse(frame.sequence_id, status, rlResponse, sizeof(rlResponse));
+    if (rlResponseLen > 0 && writer != nullptr) {
+      writer(rlResponse, rlResponseLen, userData);
+    }
+    rlFrameReader.Reset();
+    return rlResponseLen > 0;
+  }
+
+  if (frame.message_type != rl_serial_v0::kMsgGetStateReq) {
+    rlFrameReader.Reset();
+    return false;
+  }
+
+  rl_serial_v0::TelemetryState state;
+  state.roll = ypr[2] * radPerDeg;
+  state.pitch = ypr[1] * radPerDeg;
+
+  const unsigned long nowMicros = micros();
+  const float dt = (rlTelemetryHasPrev && nowMicros != rlPrevTelemetryMicros)
+                       ? (nowMicros - rlPrevTelemetryMicros) / 1000000.0f
+                       : 0.0f;
+#ifdef IMU_ICM42670
+  if (icmQ) {
+    state.angular_velocity_x = icm.gx_real * radPerDeg;
+    state.angular_velocity_y = icm.gy_real * radPerDeg;
+    state.angular_velocity_z = icm.gz_real * radPerDeg;
+  } else
+#endif
+      if (dt > 0.0f) {
+    state.angular_velocity_x = (ypr[2] - rlPrevYprDeg[2]) * radPerDeg / dt;
+    state.angular_velocity_y = (ypr[1] - rlPrevYprDeg[1]) * radPerDeg / dt;
+    state.angular_velocity_z = (ypr[0] - rlPrevYprDeg[0]) * radPerDeg / dt;
+  }
+  for (byte i = 0; i < 3; i++) {
+    rlPrevYprDeg[i] = ypr[i];
+  }
+  rlPrevTelemetryMicros = nowMicros;
+  rlTelemetryHasPrev = true;
+
+  bool jointFeedbackValid = true;
+  for (byte i = 0; i < rl_serial_v0::kTargetCount; i++) {
+    const byte jointIndex = DOF - WALKING_DOF + i;
+    state.joint_feedback[i] = currentAng[jointIndex] * radPerDeg;
+    jointFeedbackValid = jointFeedbackValid && connectedFeedbackServo[jointIndex] > 0;
+  }
+
+  uint16_t status = 0;
+  if (updateGyroQ && (icmQ || mpuQ)) {
+    status |= rl_serial_v0::kStatusTelemetryValid;
+  }
+  if (jointFeedbackValid) {
+    status |= rl_serial_v0::kStatusFeedbackValid;
+  }
+  rlResponseLen =
+      rl_serial_v0::EncodeGetStateResponse(frame.sequence_id, status, state, rlResponse, sizeof(rlResponse));
+  if (rlResponseLen > 0 && writer != nullptr) {
+    writer(rlResponse, rlResponseLen, userData);
+  }
+  rlFrameReader.Reset();
+  return rlResponseLen > 0;
+}
