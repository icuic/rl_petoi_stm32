+bool readExact(Stream *serialPort, uint8_t *buffer, size_t len, unsigned long timeoutMs) {
+  size_t received = 0;
+  const unsigned long start = millis();
+  while (received < len && millis() - start < timeoutMs) {
+    if (serialPort->available()) {
+      buffer[received++] = static_cast<uint8_t>(serialPort->read());
+    }
+  }
+  return received == len;
+}
