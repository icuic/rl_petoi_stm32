<mujoco model="simple_quadruped">
  <compiler angle="radian" coordinate="local"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="0.2" armature="0.01" limited="true"/>
    <geom friction="1.0 0.1 0.01" rgba="0.7 0.75 0.8 1"/>
    <position kp="10" ctrllimited="true" forcelimited="true" forcerange="-3 3"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.2 0.25 0.25" rgb2="0.35 0.4 0.4"/>
    <material name="grid" texture="grid" texrepeat="4 4"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="5 5 0.05" material="grid"/>

    <body name="torso" pos="0 0 0.22">
      <freejoint name="root"/>
      <geom name="torso_geom" type="box" size="0.16 0.08 0.035" mass="0.45"/>

      <body name="front_left_thigh" pos="0.10 0.065 0">
        <joint name="front_left_hip" type="hinge" axis="0 1 0" range="-0.9 0.9"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.014" mass="0.035"/>
        <body name="front_left_calf" pos="0 0 -0.095">
          <joint name="front_left_knee" type="hinge" axis="0 1 0" range="-1.4 0.2"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.012" mass="0.025"/>
          <geom name="front_left_foot" type="sphere" pos="0 0 -0.105" size="0.018" mass="0.015" rgba="0.15 0.15 0.15 1"/>
        </body>
      </body>

      <body name="front_right_thigh" pos="0.10 -0.065 0">
        <joint name="front_right_hip" type="hinge" axis="0 1 0" range="-0.9 0.9"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.014" mass="0.035"/>
        <body name="front_right_calf" pos="0 0 -0.095">
          <joint name="front_right_knee" type="hinge" axis="0 1 0" range="-1.4 0.2"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.012" mass="0.025"/>
          <geom name="front_right_foot" type="sphere" pos="0 0 -0.105" size="0.018" mass="0.015" rgba="0.15 0.15 0.15 1"/>
        </body>
      </body>

      <body name="rear_left_thigh" pos="-0.10 0.065 0">
        <joint name="rear_left_hip" type="hinge" axis="0 1 0" range="-0.9 0.9"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.014" mass="0.035"/>
        <body name="rear_left_calf" pos="0 0 -0.095">
          <joint name="rear_left_knee" type="hinge" axis="0 1 0" range="-1.4 0.2"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.012" mass="0.025"/>
          <geom name="rear_left_foot" type="sphere" pos="0 0 -0.105" size="0.018" mass="0.015" rgba="0.15 0.15 0.15 1"/>
        </body>
      </body>

      <body name="rear_right_thigh" pos="-0.10 -0.065 0">
        <joint name="rear_right_hip" type="hinge" axis="0 1 0" range="-0.9 0.9"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.014" mass="0.035"/>
        <body name="rear_right_calf" pos="0 0 -0.095">
          <joint name="rear_right_knee" type="hinge" axis="0 1 0" range="-1.4 0.2"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.095" size="0.012" mass="0.025"/>
          <geom name="rear_right_foot" type="sphere" pos="0 0 -0.105" size="0.018" mass="0.015" rgba="0.15 0.15 0.15 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="front_left_hip_pos" joint="front_left_hip" ctrlrange="-0.8 0.8"/>
    <position name="front_left_knee_pos" joint="front_left_knee" ctrlrange="-1.3 0.1"/>
    <position name="front_right_hip_pos" joint="front_right_hip" ctrlrange="-0.8 0.8"/>
    <position name="front_right_knee_pos" joint="front_right_knee" ctrlrange="-1.3 0.1"/>
    <position name="rear_left_hip_pos" joint="rear_left_hip" ctrlrange="-0.8 0.8"/>
    <position name="rear_left_knee_pos" joint="rear_left_knee" ctrlrange="-1.3 0.1"/>
    <position name="rear_right_hip_pos" joint="rear_right_hip" ctrlrange="-0.8 0.8"/>
    <position name="rear_right_knee_pos" joint="rear_right_knee" ctrlrange="-1.3 0.1"/>
  </actuator>
</mujoco>
