<mujoco model="bittle_like_v1_visual">
  <compiler angle="radian" coordinate="local"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="0.18" armature="0.008" limited="true"/>
    <geom friction="1.1 0.08 0.01" rgba="0.62 0.68 0.72 1"/>
    <position kp="12" ctrllimited="true" forcelimited="true" forcerange="-3.5 3.5"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.22 0.25 0.25" rgb2="0.36 0.4 0.4"/>
    <material name="grid" texture="grid" texrepeat="4 4"/>
    <material name="shell_black" rgba="0.07 0.08 0.09 1"/>
    <material name="petoi_yellow" rgba="0.95 0.68 0.08 1"/>
    <material name="petoi_blue" rgba="0.08 0.18 0.72 1"/>
    <material name="leg_red" rgba="0.82 0.08 0.16 1"/>
    <material name="servo_black" rgba="0.03 0.03 0.035 1"/>
    <material name="foot_blue" rgba="0.05 0.12 0.6 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="5 5 0.05" material="grid"/>

    <body name="torso" pos="0 0 0.17">
      <freejoint name="root"/>

      <!-- Visual proportions target Bittle's roughly 190-200 mm body length class. -->
      <geom name="lower_chassis" type="box" pos="-0.005 0 0.005" size="0.095 0.045 0.020" mass="0.16" material="petoi_yellow"/>
      <geom name="top_shell" type="box" pos="-0.018 0 0.033" size="0.075 0.043 0.018" mass="0.10" material="shell_black"/>
      <geom name="front_chest" type="box" pos="0.085 0 0.012" size="0.025 0.042 0.028" mass="0.045" material="petoi_yellow"/>
      <geom name="rear_shell" type="box" pos="-0.100 0 0.010" size="0.022 0.038 0.025" mass="0.035" material="petoi_yellow"/>

      <body name="head_neck_visual" pos="0.120 0 0.025">
        <geom name="neck_blue_left" type="sphere" pos="-0.008 0.030 -0.006" size="0.018" mass="0.008" material="petoi_blue"/>
        <geom name="neck_blue_right" type="sphere" pos="-0.008 -0.030 -0.006" size="0.018" mass="0.008" material="petoi_blue"/>
        <geom name="head" type="box" pos="0.026 0 0.010" size="0.033 0.027 0.025" mass="0.035" material="petoi_yellow"/>
        <geom name="snout" type="box" pos="0.060 0 0.006" size="0.018 0.020 0.016" mass="0.010" material="petoi_yellow"/>
        <geom name="left_ear" type="box" pos="0.010 0.016 0.040" size="0.008 0.006 0.018" mass="0.003" material="petoi_yellow"/>
        <geom name="right_ear" type="box" pos="0.010 -0.016 0.040" size="0.008 0.006 0.018" mass="0.003" material="petoi_yellow"/>
      </body>

      <body name="tail_visual" pos="-0.115 0 0.032">
        <geom name="tail" type="capsule" fromto="0 0 0 -0.055 0 0.050" size="0.008" mass="0.012" material="shell_black"/>
      </body>

      <body name="front_left_thigh" pos="0.064 0.062 0">
        <joint name="front_left_hip" type="hinge" axis="0 1 0" range="-0.85 0.85"/>
        <geom name="front_left_hip_servo" type="box" pos="0 0 0" size="0.018 0.013 0.022" mass="0.018" material="servo_black"/>
        <geom name="front_left_upper_cover" type="capsule" fromto="0 0 0 0.008 0 -0.070" size="0.013" mass="0.024" material="leg_red"/>
        <body name="front_left_calf" pos="0.008 0 -0.070">
          <joint name="front_left_knee" type="hinge" axis="0 1 0" range="-1.35 0.15"/>
          <geom name="front_left_knee_servo" type="box" pos="0 0 0" size="0.016 0.012 0.018" mass="0.014" material="servo_black"/>
          <geom name="front_left_lower_link" type="capsule" fromto="0 0 0 -0.014 0 -0.082" size="0.010" mass="0.020" material="petoi_blue"/>
          <geom name="front_left_foot" type="sphere" pos="-0.014 0 -0.096" size="0.017" mass="0.014" material="foot_blue"/>
        </body>
      </body>

      <body name="front_right_thigh" pos="0.064 -0.062 0">
        <joint name="front_right_hip" type="hinge" axis="0 1 0" range="-0.85 0.85"/>
        <geom name="front_right_hip_servo" type="box" pos="0 0 0" size="0.018 0.013 0.022" mass="0.018" material="servo_black"/>
        <geom name="front_right_upper_cover" type="capsule" fromto="0 0 0 0.008 0 -0.070" size="0.013" mass="0.024" material="leg_red"/>
        <body name="front_right_calf" pos="0.008 0 -0.070">
          <joint name="front_right_knee" type="hinge" axis="0 1 0" range="-1.35 0.15"/>
          <geom name="front_right_knee_servo" type="box" pos="0 0 0" size="0.016 0.012 0.018" mass="0.014" material="servo_black"/>
          <geom name="front_right_lower_link" type="capsule" fromto="0 0 0 -0.014 0 -0.082" size="0.010" mass="0.020" material="petoi_blue"/>
          <geom name="front_right_foot" type="sphere" pos="-0.014 0 -0.096" size="0.017" mass="0.014" material="foot_blue"/>
        </body>
      </body>

      <body name="rear_left_thigh" pos="-0.076 0.062 0">
        <joint name="rear_left_hip" type="hinge" axis="0 1 0" range="-0.85 0.85"/>
        <geom name="rear_left_hip_servo" type="box" pos="0 0 0" size="0.018 0.013 0.022" mass="0.018" material="servo_black"/>
        <geom name="rear_left_upper_cover" type="capsule" fromto="0 0 0 -0.008 0 -0.070" size="0.013" mass="0.024" material="leg_red"/>
        <body name="rear_left_calf" pos="-0.008 0 -0.070">
          <joint name="rear_left_knee" type="hinge" axis="0 1 0" range="-1.35 0.15"/>
          <geom name="rear_left_knee_servo" type="box" pos="0 0 0" size="0.016 0.012 0.018" mass="0.014" material="servo_black"/>
          <geom name="rear_left_lower_link" type="capsule" fromto="0 0 0 0.014 0 -0.082" size="0.010" mass="0.020" material="petoi_blue"/>
          <geom name="rear_left_foot" type="sphere" pos="0.014 0 -0.096" size="0.017" mass="0.014" material="foot_blue"/>
        </body>
      </body>

      <body name="rear_right_thigh" pos="-0.076 -0.062 0">
        <joint name="rear_right_hip" type="hinge" axis="0 1 0" range="-0.85 0.85"/>
        <geom name="rear_right_hip_servo" type="box" pos="0 0 0" size="0.018 0.013 0.022" mass="0.018" material="servo_black"/>
        <geom name="rear_right_upper_cover" type="capsule" fromto="0 0 0 -0.008 0 -0.070" size="0.013" mass="0.024" material="leg_red"/>
        <body name="rear_right_calf" pos="-0.008 0 -0.070">
          <joint name="rear_right_knee" type="hinge" axis="0 1 0" range="-1.35 0.15"/>
          <geom name="rear_right_knee_servo" type="box" pos="0 0 0" size="0.016 0.012 0.018" mass="0.014" material="servo_black"/>
          <geom name="rear_right_lower_link" type="capsule" fromto="0 0 0 0.014 0 -0.082" size="0.010" mass="0.020" material="petoi_blue"/>
          <geom name="rear_right_foot" type="sphere" pos="0.014 0 -0.096" size="0.017" mass="0.014" material="foot_blue"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="front_left_hip_pos" joint="front_left_hip" ctrlrange="-0.75 0.75"/>
    <position name="front_left_knee_pos" joint="front_left_knee" ctrlrange="-1.25 0.05"/>
    <position name="front_right_hip_pos" joint="front_right_hip" ctrlrange="-0.75 0.75"/>
    <position name="front_right_knee_pos" joint="front_right_knee" ctrlrange="-1.25 0.05"/>
    <position name="rear_left_hip_pos" joint="rear_left_hip" ctrlrange="-0.75 0.75"/>
    <position name="rear_left_knee_pos" joint="rear_left_knee" ctrlrange="-1.25 0.05"/>
    <position name="rear_right_hip_pos" joint="rear_right_hip" ctrlrange="-0.75 0.75"/>
    <position name="rear_right_knee_pos" joint="rear_right_knee" ctrlrange="-1.25 0.05"/>
  </actuator>
</mujoco>
